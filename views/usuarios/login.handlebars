

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 rounded-4" style="width: 400px;">
        
        <h1 class="text-center mb-4 text-primary fw-bold">
            FAÇA O SEU LOGIN
        </h1>

        <form action="/usuarios/login" method="POST">

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Email
                </label>

                <input 
                    type="email" 
                    name="email"
                    class="form-control form-control-lg"
                    placeholder="Digite o seu email"
                >
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">
                    Senha
                </label>

                <input 
                    type="password" 
                    name="senha"
                    class="form-control form-control-lg"
                    placeholder="Digite a sua senha"
                >
            </div>

            <div class="d-grid">
                <button class="btn btn-primary btn-lg rounded-3">
                    Entrar
                </button>
            </div>

        </form>

    </div>
</div>