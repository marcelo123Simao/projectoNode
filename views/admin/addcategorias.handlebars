{{#each erros}}
  <div class="alert alert-danger">
    {{msg}}
  </div>
{{/each}}

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow">
        <div class="card-header bg-dark text-white">
          <h4 class="mb-0">Nova Categoria</h4>
        </div>

        <div class="card-body">
          <form action="/admin/categorias/nova" method="POST">

            <!-- Nome -->
            <div class="mb-3">
              <label for="nome" class="form-label fw-bold">Nome da Categoria</label>
              <input type="text" 
                     class="form-control" 
                     id="nome" 
                     name="nome" 
                     placeholder="Digite o nome da categoria" 
                     >
            </div>

            <!-- Slug -->
            <div class="mb-3">
              <label for="slug" class="form-label fw-bold">Slug da Categoria</label>
              <input type="text" 
                     class="form-control" 
                     id="slug" 
                     name="slug" 
                     placeholder="ex: tecnologia-web" 
                    >
              <div class="form-text">
                O slug é usado na URL (sem espaços ou acentos).
              </div>
            </div>

            <!-- Botão -->
            <div class="d-grid">
              <button type="submit" class="btn btn-dark">
                Adicionar Categoria
              </button>
            </div>

          </form>
        </div>

      </div>

    </div>
  </div>
</div>