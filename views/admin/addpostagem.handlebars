{{#each erros}}
  <div class="alert alert-danger">
    {{msg}}
  </div>
{{/each}}

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow">
        <div class="card-header bg-dark text-white">
          <h4 class="mb-0 text-center">Cadastrar novas Postagens </h4>
        </div>

        <div class="card-body">
          <form action="/admin/postagens/nova" method="POST">
            
            <!-- titulo -->
            <div class="mb-3">
              <label for="titulo" class="form-label fw-bold">Titulo da Categoria</label>
              <input type="text" 
                     class="form-control" 
                    
                     name="titulo" 
                     placeholder="Digite o titulo da categoria" 
                    >
            </div>

            <!-- Slug -->
            <div class="mb-3">
              <label for="slug" class="form-label fw-bold">Slug da Categoria</label>
              <input type="text" 
                     class="form-control" 
                     
                     name="slug" 
                     placeholder="ex: tecnologia-web" 
                    >
            </div>

            <!-- Descrição -->
            <div class="mb-3">
              <label for="descricao" class="form-label fw-bold">Descrição</label>
              <input type="text" 
                     class="form-control" 
        
                     name="descricao" 
                     class="form-control"
                    >
            </div>

             <!-- Conteúdo -->
            <div class="mb-3">
              <label for="descricao" class="form-label fw-bold">Conteúdo</label>
              <textarea name="conteudo" class="form-control"></textarea>
            </div>

               <!--AREA DA CATEGORIA -->
               <label for="categoria" class="form-label fw-bold">Categoria</label>
              <select name="categoria" class="custom-select">
                {{#each categorias}}
                <option value="{{_id}}">{{nome}}</option>
                  {{else}}  
                  <option value="0">Nenhuma categoria registrada</option>
                {{/each}}
              </select> 

            <!-- Botão -->
            <div class="d-grid">
              <button type="submit" class="btn btn-dark mt-4">
                Criar Postagem
              </button>
            </div>

          </form>
        </div>

      </div>

    </div>
  </div>
</div>