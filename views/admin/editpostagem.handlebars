{{#each erros}}
  <div class="alert alert-danger">
    {{msg}}
  </div>
{{/each}}

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow">
        <div class="card-header bg-dark text-white">
          <h4 class="mb-0">Editar postagens</h4>
        </div>

        <div class="card-body">
          <form action="/admin/postagens/edit" method="POST">
            <input type="text" name="id" value="{{postagem._id}}">
            
            <!-- titulo -->
            <div class="mb-3">
              <label for="titulo" class="form-label fw-bold">Titulo da Categoria</label>
              <input type="text" 
                     class="form-control" 
                     value="{{postagem.titulo}}"
                     name="titulo" 
                     placeholder="Digite o titulo da categoria" 
                    >
            </div>

            <!-- Slug -->
            <div class="mb-3">
              <label for="slug" class="form-label fw-bold">Slug da Categoria</label>
              <input type="text" 
                     class="form-control" 
                     value="{{postagem.slug}}"
                     name="slug" 
                     placeholder="ex: tecnologia-web" 
                    >
            </div>

            <!-- Descrição -->
            <div class="mb-3">
              <label for="descricao" class="form-label fw-bold">Descrição</label>
              <input type="text" 
                     class="form-control" 
                     value="{{postagem.descricao}}"
                     name="descricao" 
                     class="form-control"
                    >
            </div>

             <!-- Conteúdo -->
            <div class="mb-3">
              <label for="descricao" class="form-label fw-bold">Conteúdo</label>
              <textarea name="conteudo" class="form-control">{{postagem.conteudo}}</textarea>
            </div>

               <!--AREA DA CATEGORIA -->
               <label for="categoria" class="form-label fw-bold">Categoria</label>
              <select name="categoria" class="form-select">
                {{#each categorias}}
                    {{#ifEquals _id ../postagem.categoria}}
                    <option value="{{_id}}" selected>{{nome}}</option>
                    {{else}}
                    <option value="{{_id}}">{{nome}}</option>
                    {{/ifEquals}}
                {{/each}}
                </select>

            <!-- Botão -->
            <div class="d-grid">
              <button type="submit" class="btn btn-dark mt-4">
                Salvar Postagem editada
              </button>
            </div>

          </form>
        </div>

      </div>

    </div>
  </div>
</div>